# --- Slack ---
# Bot User OAuth token (xoxb-...). Scopes: channels:history, chat:write, channels:read
# (add groups:* equivalents if the ticket channel is private).
SLACK_BOT_TOKEN=

# App-level signing secret, used to verify Slack Events API requests.
SLACK_SIGNING_SECRET=

# The single channel the bot watches for new tickets (e.g. C0123456789).
SLACK_TICKET_CHANNEL_ID=

# --- App ---
# Base URL the tracker is reachable at, used to build links in Slack replies.
BASE_URL=http://localhost:5000

# SQLAlchemy database URL. Defaults to a local SQLite file if unset.
DATABASE_URL=sqlite:///ticketing.db

# Comma-separated fixed list of team members for the name picker (§7.3).
# If unset, a sensible default list is used (see app/config.py).
TEAM_MEMBERS=Henry,Raj,Priya,Sam
